[Defines]
  INF_VERSION                    = 0x0001001B
  BASE_NAME                      = MonoConfigurationManagerDxe
  FILE_GUID                      = ba5850ec-1f5a-4cf7-a61d-39b96a5a6fde
  MODULE_TYPE                    = DXE_DRIVER
  VERSION_STRING                 = 1.0
  ENTRY_POINT                    = ConfigurationManagerDxeInitialize

[Sources]
