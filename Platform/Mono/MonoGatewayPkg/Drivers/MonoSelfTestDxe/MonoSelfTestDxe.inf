[Defines]
  INF_VERSION                    = 0x0001001A
  BASE_NAME                      = MonoSelfTestDxe
  FILE_GUID                      = 5e9de0ca-41f5-4b82-a4c2-5f7a1dbb2a43
  MODULE_TYPE                    = DXE_DRIVER
  VERSION_STRING                 = 1.0
  ENTRY_POINT                    = MonoSelfTestDxeEntryPoint

[Sources]
